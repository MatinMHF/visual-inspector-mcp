    "ai-agent-tools"
  ],
  "author": "Matin Farahani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatinMHF/visual-inspector-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/MatinMHF/visual-inspector-mcp/issues"
  },
  "homepage": "https://github.com/MatinMHF/visual-inspector-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  }
}
